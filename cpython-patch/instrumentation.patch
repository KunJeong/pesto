+static void
+pesto_emit(PyObject *exception)
+{
+    const char *type_name = "?";
+    if (exception && PyExceptionClass_Check(exception)) {
+        type_name = ((PyTypeObject *)exception)->tp_name;
+    }
+    void *buf[128];
+    int n = backtrace(buf, 128);
+    fprintf(stderr, "[PESTO-BEGIN type=%s]\n", type_name);
+    backtrace_symbols_fd(buf, n, fileno(stderr));
+    fprintf(stderr, "[PESTO-END]\n");
+}
